{
  "name": "cryptic-mechanic",
  "productName": "CrypticMechanic",
  "private": true,
  "version": "1.0.0",
  "description": "Translate cryptic developer error logs into human-readable diagnoses and actionable fixes.",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --win portable"
  },
  "build": {
    "appId": "com.crypticmechanic.app",
    "productName": "CrypticMechanic",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/icon.png"
    ],
    "win": {
      "target": "portable",
      "icon": "public/icon.png"
    },
    "portable": {
      "artifactName": "CrypticMechanic-Portable.exe"
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
